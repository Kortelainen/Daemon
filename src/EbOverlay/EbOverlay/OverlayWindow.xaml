<Window x:Class="EbOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EbOverlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        IsHitTestVisible="False">

    <Window.Resources>
        <!-- Shared drop shadow — soft dark halo, readable on any background -->
        <DropShadowEffect x:Key="TextShadow"
                          Color="Black"
                          BlurRadius="4"
                          ShadowDepth="1"
                          Opacity="0.95"
                          Direction="315" />

        <!-- Base style applied to every overlay TextBlock -->
        <Style x:Key="OverlayText" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#66FF99" />
            <Setter Property="FontFamily"  Value="Courier New" />
            <Setter Property="FontSize"    Value="13" />
            <Setter Property="FontWeight"  Value="Bold" />
            <Setter Property="Effect"      Value="{StaticResource TextShadow}" />
        </Style>

        <Style x:Key="OverlayTextSmall" TargetType="TextBlock" BasedOn="{StaticResource OverlayText}">
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Resources>

    <!-- Root canvas — full screen, all zones positioned in code-behind via PositionAllElements() -->
    <Canvas x:Name="RootCanvas">

        <!-- [TOP-LEFT] App name — filled by AppNameZone in M2 -->
        <TextBlock x:Name="AppNameText"
                   Style="{StaticResource OverlayText}"
                   Opacity="0"
                   Text="—" />

        <!-- [TOP-RIGHT] Clock — filled by ClockZone in M2 -->
        <TextBlock x:Name="ClockText"
                   Style="{StaticResource OverlayText}"
                   Opacity="0.6"
                   Text="00:00" />

        <!-- [BOT-RIGHT] System metrics — filled by MetricsZone in M3 -->
        <StackPanel x:Name="MetricsPanel"
                    Orientation="Vertical"
                    HorizontalAlignment="Right"
                    Opacity="0.5">
            <TextBlock x:Name="CpuText"
                       Style="{StaticResource OverlayTextSmall}"
                       Text="CPU  --%"
                       HorizontalAlignment="Right" />
            <TextBlock x:Name="RamText"
                       Style="{StaticResource OverlayTextSmall}"
                       Text="RAM  --/-- GB"
                       HorizontalAlignment="Right" />
        </StackPanel>

        <!-- [BOT-LEFT] Network metrics — filled by NetworkMetrics in M3 -->
        <StackPanel x:Name="NetPanel"
                    Orientation="Vertical"
                    Opacity="0.5">
            <TextBlock x:Name="NetUpText"
                       Style="{StaticResource OverlayTextSmall}"
                       Text="↑  --" />
            <TextBlock x:Name="NetDownText"
                       Style="{StaticResource OverlayTextSmall}"
                       Text="↓  --" />
        </StackPanel>

        <!-- [MID-RIGHT] Sprite zone — filled by SpriteZone in M4 -->
        <Image x:Name="SpriteImage"
               Width="96"
               Height="96"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               Opacity="0.85" />

    </Canvas>
</Window>
