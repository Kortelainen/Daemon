<Window x:Class="EbOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:EbOverlay.Controls"
        Title="EbOverlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        IsHitTestVisible="False">

    <Window.Resources>
        <DropShadowEffect x:Key="TextShadow"
                          Color="Black"
                          BlurRadius="4"
                          ShadowDepth="1"
                          Opacity="0.95"
                          Direction="315" />

        <Style x:Key="OverlayText" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#66FF99" />
            <Setter Property="FontFamily"  Value="Courier New" />
            <Setter Property="FontSize"    Value="13" />
            <Setter Property="FontWeight"  Value="Bold" />
            <Setter Property="Effect"      Value="{StaticResource TextShadow}" />
        </Style>

        <Style x:Key="OverlayTextSmall" TargetType="TextBlock" BasedOn="{StaticResource OverlayText}">
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Resources>

    <Canvas x:Name="RootCanvas">

        <!-- [TOP-LEFT] App name -->
        <TextBlock x:Name="AppNameText"
                   Style="{StaticResource OverlayText}"
                   Opacity="0"
                   Text="—" />

        <!-- [TOP-RIGHT] Clock -->
        <TextBlock x:Name="ClockText"
                   Style="{StaticResource OverlayText}"
                   Opacity="0.6"
                   Text="00:00" />

        <!-- [BOT-RIGHT] System + process metrics -->
        <StackPanel x:Name="MetricsPanel"
                    Orientation="Vertical"
                    Opacity="0.5"
                    Width="200">

            <TextBlock x:Name="CpuText"
                       Style="{StaticResource OverlayTextSmall}"
                       Text="CPU  --%"
                       HorizontalAlignment="Right" />
            <ctrl:MetricBar x:Name="CpuBar"
                            Height="3"
                            Margin="0,2,0,6" />

            <TextBlock x:Name="RamText"
                       Style="{StaticResource OverlayTextSmall}"
                       Text="RAM  -- | -- GB"
                       HorizontalAlignment="Right" />
            <ctrl:MetricBar x:Name="RamBar"
                            Height="3"
                            Margin="0,2,0,0" />
        </StackPanel>

        <!-- [BOT-LEFT] Network metrics + sparklines -->
        <StackPanel x:Name="NetPanel"
                    Orientation="Vertical"
                    Opacity="0.5"
                    Width="140">

            <TextBlock x:Name="NetUpText"
                       Style="{StaticResource OverlayTextSmall}"
                       Text="↑  --" />
            <ctrl:Sparkline x:Name="UpSparkline"
                            Height="20"
                            Margin="0,2,0,4" />

            <TextBlock x:Name="NetDownText"
                       Style="{StaticResource OverlayTextSmall}"
                       Text="↓  --" />
            <ctrl:Sparkline x:Name="DownSparkline"
                            Height="20"
                            Margin="0,2,0,0" />
        </StackPanel>

        <!-- [MID-RIGHT] Sprite zone -->
        <Image x:Name="SpriteImage"
               Width="96"
               Height="96"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               Opacity="0.85" />

    </Canvas>
</Window>
